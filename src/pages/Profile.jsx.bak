import React, { useState, useEffect, useRef } from 'react';
import { Helmet } from 'react-helmet';
import { motion } from 'framer-motion';
import { User, Camera, Save, Trophy, Gamepad2, Users, Lock, Bell, Sparkles, Palette, LogOut } from 'lucide-react';
import Layout from '@/components/Layout';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { useToast } from '@/components/ui/use-toast';
import { supabase } from '@/supabaseClient';
import { useAuth } from '@/contexts/SupabaseAuthContext';

const TABS = [
  { id: 'profile', label: 'Perfil', icon: User },
  { id: 'security', label: 'Seguridad', icon: Lock },
  { id: 'appearance', label: 'Apariencia', icon: Palette },
  { id: 'notifications', label: 'Notificaciones', icon: Bell },
  { id: 'nova', label: 'Nova IA', icon: Sparkles },
];

const Profile = () => {
  const { user, signOut, updateUserPassword } = useAuth();
  const { toast } = useToast();
  const [activeTab, setActiveTab] = useState('profile');
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [profile, setProfile] = useState({ username: '', bio: '', avatar_url: '' });
  const [stats, setStats] = useState({ totalScore: 0, gamesPlayed: 0, topGame: '-' });
  const [topScores, setTopScores] = useState([]);
  const [passwords, setPasswords] = useState({ new: '', confirm: '' });
  const [savingPass, setSavingPass] = useState(false);
  const fileRef = useRef(null);

  useEffect(() => {
    if (user) { fetchProfile(); fetchStats(); }
  }, [user]);

  const fetchProfile = async () => {
    setLoading(true);
    const { data } = await supabase.from('profiles').select('*').eq('id', user.id).single();
    if (data) setProfile({ username: data.username || '', bio: data.bio || '', avatar_url: data.avatar_url || '' });
    setLoading(false);
  };

  const fetchStats = async () => {
    const { data: scores } = await supabase.from('scores').select('score, game').eq('user_id', user.id).order('score', { ascending: false });
    if (scores && scores.length > 0) {
      const total = scores.reduce((a, b) => a + b.score, 0);
      const topGame = scores[0].game;
      setStats({ totalScore: total, gamesPlayed: scores.length, topGame });
      setTopScores(scores.slice(0, 5));
    }
  };

  const handleSave = async () => {
    if (!profile.username.trim()) {
      toast({ variant: 'destructive', title: 'Error', description: 'El username no puede estar vacío.' });
      return;
    }
    setSaving(true);
    const { error } = await supabase.from('profiles').upsert({
      id: user.id,
      username: profile.username.trim(),
      bio: profile.bio.trim(),
      avatar_url: profile.avatar_url,
      updated_at: new Date().toISOString()
    });
    setSaving(false);
    if (error) {
      toast({ variant: 'destructive', title: 'Error', description: error.message });
    } else {
      toast({ title: '✅ Perfil guardado!' });
    }
  };

  const handleAvatar = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    if (file.size > 2 * 1024 * 1024) {
      toast({ variant: 'destructive', title: 'Error', description: 'Imagen menor a 2MB.' });
      return;
    }
    const reader = new FileReader();
    reader.onload = (ev) => setProfile(prev => ({ ...prev, avatar_url: ev.target.result }));
    reader.readAsDataURL(file);
    toast({ title: '📸 Avatar actualizado', description: 'Guarda el perfil para conservarlo.' });
  };

  const handleChangePassword = async () => {
    if (passwords.new.length < 6) {
      toast({ variant: 'destructive', title: 'Error', description: 'Mínimo 6 caracteres.' });
      return;
    }
    if (passwords.new !== passwords.confirm) {
      toast({ variant: 'destructive', title: 'Error', description: 'Las contraseñas no coinciden.' });
      return;
    }
    setSavingPass(true);
    const { error } = await updateUserPassword(passwords.new);
    setSavingPass(false);
    if (!error) {
      setPasswords({ new: '', confirm: '' });
      toast({ title: '🔒 Contraseña actualizada!' });
    }
  };

  const avatarSrc = profile.avatar_url || `https://api.dicebear.com/7.x/avataaars/svg?seed=${profile.username || user?.email}`;

  if (loading) return (
    <Layout>
      <div className="flex items-center justify-center h-64">
        <div className="w-12 h-12 border-4 border-dashed rounded-full animate-spin border-blue-500"></div>
      </div>
    </Layout>
  );

  return (
    <Layout>
      <Helmet><title>Perfil - Fusion Core</title></Helmet>
      <div className="max-w-4xl mx-auto space-y-6">

        {/* Header */}
        <motion.div initial={{ opacity: 0, y: -20 }} animate={{ opacity: 1, y: 0 }}
          className="glass-effect rounded-2xl p-6">
          <div className="flex flex-col md:flex-row gap-6 items-center md:items-start">
            <div className="flex flex-col items-center gap-2">
              <div className="relative group cursor-pointer" onClick={() => fileRef.current?.click()}>
                <img src={avatarSrc} alt="avatar"
                  className="w-24 h-24 rounded-full border-4 border-blue-500 object-cover shadow-lg shadow-blue-900/30" />
                <div className="absolute inset-0 rounded-full bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                  <Camera className="w-7 h-7 text-white" />
                </div>
              </div>
              <input ref={fileRef} type="file" accept="image/*" className="hidden" onChange={handleAvatar} />
              <p className="text-gray-500 text-xs">Click para cambiar</p>
            </div>
            <div className="flex-1 text-center md:text-left">
              <h1 className="text-2xl font-bold text-white">{profile.username || 'Sin username'}</h1>
              <p className="text-gray-400 text-sm mt-1">{profile.bio || 'Sin bio'}</p>
              <p className="text-gray-500 text-xs mt-1">{user?.email}</p>
            </div>
            <Button onClick={signOut} variant="outline"
              className="border-red-500/50 text-red-400 hover:bg-red-500/10">
              <LogOut className="w-4 h-4 mr-2" /> Cerrar sesión
            </Button>
          </div>
        </motion.div>

        {/* Stats */}
        <div className="grid grid-cols-3 gap-4">
          {[
            { icon: Trophy, label: 'Puntos', value: stats.totalScore, color: 'text-yellow-400', bg: 'from-yellow-500/20 to-orange-500/20' },
            { icon: Gamepad2, label: 'Partidas', value: stats.gamesPlayed, color: 'text-cyan-400', bg: 'from-cyan-500/20 to-blue-500/20' },
            { icon: Trophy, label: 'Top Juego', value: stats.topGame, color: 'text-purple-400', bg: 'from-purple-500/20 to-pink-500/20' },
          ].map((s, i) => (
            <motion.div key={i} initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: i * 0.1 }}
              className={`glass-effect rounded-xl p-4 text-center bg-gradient-to-br ${s.bg}`}>
              <s.icon className={`w-5 h-5 mx-auto mb-1 ${s.color}`} />
              <p className={`text-xl font-bold font-mono ${s.color}`}>{s.value}</p>
              <p className="text-gray-400 text-xs mt-1">{s.label}</p>
            </motion.div>
          ))}
        </div>

        {/* Tabs */}
        <div className="flex gap-2 overflow-x-auto pb-1">
          {TABS.map(tab => (
            <button key={tab.id} onClick={() => setActiveTab(tab.id)}
              className={`flex items-center gap-2 px-4 py-2 rounded-lg font-medium text-sm whitespace-nowrap transition-all
                ${activeTab === tab.id ? 'bg-blue-600 text-white' : 'bg-slate-800 text-gray-400 hover:bg-slate-700'}`}>
              <tab.icon className="w-4 h-4" />
              {tab.label}
            </button>
          ))}
        </div>

        {/* Tab Content */}
        <motion.div key={activeTab} initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }}
          className="glass-effect rounded-2xl p-6">

          {activeTab === 'profile' && (
            <div className="space-y-4">
              <h2 className="text-xl font-bold text-white mb-4">Editar Perfil</h2>
              <div>
                <label className="text-gray-400 text-sm mb-2 block">Avatar predefinido</label>
                <div className="grid grid-cols-10 gap-2 mb-4">
                  {["adventurer","avataaars","big-ears","bottts","croodles","fun-emoji","icons","identicon","initials","lorelei",
                    "micah","miniavs","notionists","open-peeps","personas","pixel-art","rings","shapes","thumbs","big-smile"
                  ].map((style, i) => {
                    const seed = profile.username || user?.email || "user";
                    const url = `https://api.dicebear.com/7.x/${style}/svg?seed=${seed}`;
                    return (
                      <img key={i} src={url} alt={style}
                        onClick={() => { setProfile(prev => ({ ...prev, avatar_url: url })); toast({ title: "Avatar seleccionado" }); }}
                        className={`w-10 h-10 rounded-full cursor-pointer hover:scale-110 transition-transform border-2 ${profile.avatar_url === url ? "border-indigo-500" : "border-transparent"}`} />
                    );
                  })}
                </div>
              </div>
              <div>
                <label className="text-gray-400 text-sm mb-1 block">Username</label>
                <Input value={profile.username} onChange={e => setProfile(prev => ({ ...prev, username: e.target.value }))}
                  placeholder="Tu username..." maxLength={30}
                  className="bg-slate-800 border-slate-600 text-white focus-visible:ring-blue-500" />
              </div>
              <div>
                <label className="text-gray-400 text-sm mb-1 block">Bio</label>
                <textarea value={profile.bio} onChange={e => setProfile(prev => ({ ...prev, bio: e.target.value }))}
                  placeholder="Cuéntanos algo de ti..." maxLength={150} rows={3}
                  className="w-full bg-slate-800 border border-slate-600 rounded-lg p-3 text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none text-sm" />
                <p className="text-gray-500 text-xs text-right">{profile.bio.length}/150</p>
              </div>
              <div>
                <label className="text-gray-400 text-sm mb-1 block">Email</label>
                <Input value={user?.email || ''} disabled
                  className="bg-slate-900 border-slate-700 text-gray-500 cursor-not-allowed" />
              </div>
              <Button onClick={handleSave} disabled={saving}
                className="bg-gradient-to-r from-blue-600 to-cyan-600 text-white font-bold">
                <Save className="w-4 h-4 mr-2" />
                {saving ? 'Guardando...' : 'Guardar Perfil'}
              </Button>

              {topScores.length > 0 && (
                <div className="mt-6 pt-6 border-t border-slate-700">
                  <h3 className="text-white font-bold mb-3 flex items-center gap-2">
                    <Trophy className="text-yellow-400 w-4 h-4" /> Mis Mejores Scores
                  </h3>
                  <div className="space-y-2">
                    {topScores.map((s, i) => (
                      <div key={i} className="flex items-center justify-between p-3 bg-slate-800/50 rounded-lg">
                        <div className="flex items-center gap-3">
                          <span>{['🥇','🥈','🥉','4️⃣','5️⃣'][i]}</span>
                          <span className="text-white font-medium">{s.game}</span>
                        </div>
                        <span className="text-yellow-400 font-mono font-bold">{s.score} pts</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}

          {activeTab === 'security' && (
            <div className="space-y-4">
              <h2 className="text-xl font-bold text-white mb-4">Seguridad</h2>
              <div>
                <label className="text-gray-400 text-sm mb-1 block">Nueva contraseña</label>
                <Input type="password" value={passwords.new}
                  onChange={e => setPasswords(prev => ({ ...prev, new: e.target.value }))}
                  placeholder="Mínimo 6 caracteres..."
                  className="bg-slate-800 border-slate-600 text-white focus-visible:ring-blue-500" />
              </div>
              <div>
                <label className="text-gray-400 text-sm mb-1 block">Confirmar contraseña</label>
                <Input type="password" value={passwords.confirm}
                  onChange={e => setPasswords(prev => ({ ...prev, confirm: e.target.value }))}
                  placeholder="Repite la contraseña..."
                  className="bg-slate-800 border-slate-600 text-white focus-visible:ring-blue-500" />
              </div>
              <Button onClick={handleChangePassword} disabled={savingPass}
                className="bg-gradient-to-r from-purple-600 to-pink-600 text-white font-bold">
                <Lock className="w-4 h-4 mr-2" />
                {savingPass ? 'Actualizando...' : 'Cambiar Contraseña'}
              </Button>
            </div>
          )}

          {activeTab === 'appearance' && (
            <div className="space-y-6">
              <h2 className="text-xl font-bold text-white">Apariencia</h2>
              <div>
                <p className="text-sm text-gray-400 mb-3">Color de acento</p>
                <div className="flex gap-3 flex-wrap">
                  {[
                    { name: "Índigo", color: "#6366f1" },
                    { name: "Morado", color: "#a855f7" },
                    { name: "Cyan", color: "#06b6d4" },
                    { name: "Verde", color: "#22c55e" },
                    { name: "Rosa", color: "#ec4899" },
                    { name: "Naranja", color: "#f97316" },
                  ].map(a => (
                    <div key={a.color} onClick={() => {
                      document.documentElement.style.setProperty("--accent", a.color);
                      localStorage.setItem("fc-accent", a.color);
                      toast({ title: `Color ${a.name} aplicado` });
                    }}
                      className="w-10 h-10 rounded-full cursor-pointer hover:scale-110 transition-transform ring-2 ring-white/10 hover:ring-white/40"
                      style={{ background: a.color }} title={a.name} />
                  ))}
                </div>
              </div>
            </div>
          )}
          {activeTab === 'notifications' && (
            <div className="space-y-4">
              <h2 className="text-xl font-bold text-white">Notificaciones</h2>
              {[
                { id: "msgs", label: "Mensajes directos", desc: "Sonido al recibir un mensaje", def: true },
                { id: "groups", label: "Grupos", desc: "Notificaciones de grupos", def: true },
                { id: "friends", label: "Solicitudes de amistad", desc: "Cuando alguien te envíe una solicitud", def: true },
                { id: "gaming", label: "Logros gaming", desc: "Cuando superes tu récord", def: false },
              ].map(n => (
                <div key={n.id} className="flex items-center justify-between p-4 rounded-xl bg-slate-800/50 border border-white/5">
                  <div>
                    <p className="text-white font-medium">{n.label}</p>
                    <p className="text-gray-500 text-sm">{n.desc}</p>
                  </div>
                  <label className="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" defaultChecked={n.def} className="sr-only peer"
                      onChange={(e) => localStorage.setItem(`notif-${n.id}`, e.target.checked)} />
                    <div className="w-11 h-6 bg-slate-600 rounded-full peer peer-checked:after:translate-x-full after:content-[\'\'] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                  </label>
                </div>
              ))}
              <button onClick={() => Notification.requestPermission().then(p => toast({ title: p === "granted" ? "✅ Notificaciones activadas" : "❌ Permiso denegado" }))}
                className="btn-primary w-full py-3 rounded-xl font-semibold">
                Activar notificaciones del navegador
              </button>
            </div>
          )}
          {activeTab === 'nova' && (
            <div className="space-y-6">
              <h2 className="text-xl font-bold text-white">Nova IA</h2>
              <div className="p-4 rounded-xl bg-gradient-to-br from-pink-500/10 to-purple-500/10 border border-pink-500/20 flex items-center gap-4">
                <div className="w-12 h-12 rounded-xl bg-gradient-to-br from-pink-500 to-purple-600 flex items-center justify-center text-2xl">✨</div>
                <div>
                  <p className="text-white font-bold">Nova está activa</p>
                  <p className="text-gray-400 text-sm">Llama 3.3 70B · Memoria global · Imágenes</p>
                </div>
              </div>
              <div>
                <p className="text-sm text-gray-400 mb-3">Personalidad</p>
                <div className="grid grid-cols-1 gap-2">
                  {[
                    { id: "gamer", name: "Amigable gamer", emoji: "🎮", desc: "Entusiasta y conoce gaming" },
                    { id: "professional", name: "Seria y profesional", emoji: "💼", desc: "Formal y precisa" },
                    { id: "sarcastic", name: "Sarcástica y divertida", emoji: "😂", desc: "Humor y wit" },
                    { id: "coach", name: "Coach motivador", emoji: "💪", desc: "Energía y motivación" },
                    { id: "mysterious", name: "Misteriosa y fría", emoji: "❄️", desc: "Enigmática y concisa" },
                  ].map(p => (
                    <div key={p.id} onClick={async () => {
                      await supabase.from("nova_user_memory").upsert({ user_id: user.id, personality: p.id, updated_at: new Date().toISOString() });
                      toast({ title: `✅ ${p.name} guardada` });
                    }}
                      className="flex items-center gap-3 p-3 rounded-xl border border-white/5 hover:border-indigo-500/30 bg-slate-800/50 cursor-pointer hover:bg-indigo-500/10 transition-all">
                      <span className="text-2xl">{p.emoji}</span>
                      <div>
                        <p className="text-white text-sm font-medium">{p.name}</p>
                        <p className="text-gray-500 text-xs">{p.desc}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
              <div>
                <p className="text-sm text-gray-400 mb-2">Instrucciones personalizadas</p>
                <textarea placeholder="Ej: Respóndeme con bullet points. Sé más breve..."
                  rows={3} maxLength={300}
                  className="input-dark resize-none text-sm"
                  onChange={async (e) => {
                    clearTimeout(window._novaTimer);
                    window._novaTimer = setTimeout(async () => {
                      await supabase.from("nova_user_memory").upsert({ user_id: user.id, custom_instructions: e.target.value, updated_at: new Date().toISOString() });
                      toast({ title: "✅ Guardado" });
                    }, 1000);
                  }} />
                <p className="text-gray-600 text-xs mt-1">Se guarda automáticamente</p>
              </div>
            </div>
          )}
        </motion.div>
      </div>
    </Layout>
  );
};

export default Profile;